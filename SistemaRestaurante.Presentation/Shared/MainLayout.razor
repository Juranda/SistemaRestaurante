@inherits LayoutComponentBase
@using SistemaRestaurante.Application.InterfacesDeServicos
@inject IAutenticacaoServico Auth

<PageTitle>Sistema Restaurante</PageTitle>

<UsuarioContextoProvider>
    <div class="page">
        <div class="sidebar">
            <NavMenu />
        </div>

        <main>
            <div class="top-row px-4">
                <button class="btn btn-link p-0" @onclick="Auth.DesconectarUsuario">Desconectar</button>
            </div>

            <article class="content px-4">
                @Body
            </article>
        </main>
    </div>
</UsuarioContextoProvider>